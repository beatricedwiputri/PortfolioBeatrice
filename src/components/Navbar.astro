---
import { Github, Menu, X } from "lucide-astro";
---

<nav class="fixed top-0 w-full bg-[#0f172a]/80 backdrop-blur z-50">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center text-white">

    <!-- LOGO -->
    <h1 class="text-xl tracking-wide" style="font-family: 'Space Grotesk', serif; font-style: italic;">
      Beatrice's Portfolio
    </h1>

    <!-- DESKTOP MENU -->
    <div class="hidden md:flex items-center gap-8 text-sm">

      <a href="#about" class="nav-link">About</a>
      <a href="#education" class="nav-link">Education</a>
      <a href="#experience" class="nav-link">Experiences</a>
      <a href="#projects" class="nav-link">Projects</a>
      <a href="#certifications" class="nav-link">Certifications</a>
      <a href="#honors" class="nav-link">Honors</a>


      <!-- <a href="https://github.com/beatricedwiputri"><Github size={20} /></a> -->

      <a href="https://drive.google.com/uc?export=download&id=14MxwtT-YNxKTPObN8Ik0Se4rT_NDPQW3" class="btn">Resume</a>
    </div>

    <!-- MOBILE BUTTON -->
    <button id="menu-btn" class="md:hidden">
      <Menu />
    </button>

  </div>

  <!-- MOBILE MENU -->
  <div id="mobile-menu" class="hidden flex flex-col text-white px-6 pb-4 space-y-4 md:hidden">
    <a href="#about">About</a>
    <a href="#education">Education</a>
    <a href="#experience">Experiences</a>
    <a href="#projects">Projects</a>
    <a href="#certifications">Certifications</a>
    <a href="#honors">Honors</a>
  </div>
</nav>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {

    // ELEMENTS
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    const nav = document.querySelector("nav");

    const sections = document.querySelectorAll("section");
    const navLinks = document.querySelectorAll(".nav-link");

    // SAFETY CHECK (prevents errors)
    if (!btn || !menu || !nav) return;

    // MOBILE MENU TOGGLE
    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });

    // CLOSE MENU WHEN CLICK LINK
    document.querySelectorAll("#mobile-menu a").forEach(link => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden");
      });
    });

    // SCROLL EVENTS
    window.addEventListener("scroll", () => {

      // ACTIVE SECTION
      let current = "";

      sections.forEach((section) => {
        const sectionTop = section.offsetTop - 120;

        if (window.scrollY >= sectionTop) {
          current = section.getAttribute("id");
        }
      });

      navLinks.forEach((link) => {
        link.classList.remove("text-purple-400");

        if (link.getAttribute("href") === "#" + current) {
          link.classList.add("text-purple-400");
        }
      });

      // NAV SHADOW
      if (window.scrollY > 50) {
        nav.classList.add("shadow-lg");
      } else {
        nav.classList.remove("shadow-lg");
      }

    });

  });
</script>